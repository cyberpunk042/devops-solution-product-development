# Plane Environment — copy to plane.env and customize
# Reference: https://developers.plane.so/self-hosting/methods/docker-compose

# ── Release ──────────────────────────────────────────────────────
APP_RELEASE=stable

# ── Networking ───────────────────────────────────────────────────
# HTTP port — 8080 avoids conflict with OCMC (8000) and MC UI (3000)
LISTEN_HTTP_PORT=8080
LISTEN_HTTPS_PORT=8443

# URL Plane serves on (no trailing slash)
WEB_URL=http://localhost:8080
APP_DOMAIN=localhost
CORS_ALLOWED_ORIGINS=http://localhost:8080
API_BASE_URL=http://api:8000

# ── Security (CHANGE THESE) ──────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=changeme-replace-with-50-char-random-string
LIVE_SERVER_SECRET_KEY=changeme-live-secret

# ── PostgreSQL (Plane-dedicated) ─────────────────────────────────
PGHOST=plane-db
POSTGRES_USER=plane
POSTGRES_PASSWORD=plane
POSTGRES_DB=plane
PGDATABASE=plane
POSTGRES_PORT=5432
DATABASE_URL=postgresql://plane:plane@plane-db/plane

# ── Redis / Valkey (Plane-dedicated) ─────────────────────────────
REDIS_HOST=plane-redis
REDIS_PORT=6379
REDIS_URL=redis://plane-redis:6379/

# ── RabbitMQ ─────────────────────────────────────────────────────
RABBITMQ_HOST=plane-mq
RABBITMQ_PORT=5672
RABBITMQ_USER=plane
RABBITMQ_PASSWORD=plane
RABBITMQ_VHOST=plane
AMQP_URL=amqp://plane:plane@plane-mq:5672/plane

# ── MinIO (object storage for file uploads) ──────────────────────
USE_MINIO=1
AWS_ACCESS_KEY_ID=access-key
AWS_SECRET_ACCESS_KEY=secret-key
AWS_S3_ENDPOINT_URL=http://plane-minio:9000
AWS_S3_BUCKET_NAME=uploads
MINIO_ENDPOINT_SSL=0
AWS_REGION=

# ── Performance ───────────────────────────────────────────────────
FILE_SIZE_LIMIT=5242880
API_KEY_RATE_LIMIT=600/minute
DEBUG=0

# ── Admin Credentials (god-mode) ─────────────────────────────────────────────
# Access: http://localhost:8080/god-mode/  (after running ./scripts/plane-configure.sh)
# Generate password with: python3 -c "import secrets; print(secrets.token_urlsafe(16))"
PLANE_ADMIN_EMAIL=admin@fleet.local
PLANE_ADMIN_PASSWORD=changeme-set-a-strong-password
PLANE_INSTANCE_NAME="OpenClaw Fleet Management"
